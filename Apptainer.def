Bootstrap: docker
From: python:3.12-slim

%files
    requirements.txt /opt/infogather/requirements.txt
    base.py /opt/infogather/base.py
    arxiv.py /opt/infogather/arxiv.py
    biorxiv.py /opt/infogather/biorxiv.py
    medrxiv.py /opt/infogather/medrxiv.py
    All_embedding.py /opt/infogather/All_embedding.py

%post
    set -eu
    pip install --no-cache-dir -r /opt/infogather/requirements.txt

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1

%runscript
    cd "$PWD"
    exec python /opt/infogather/All_embedding.py "$@"
