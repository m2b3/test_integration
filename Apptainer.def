Bootstrap: docker
From: python:3.12-slim

%files
    requirements.txt /opt/infogather/requirements.txt
    base.py /opt/infogather/base.py
    embedding.py /opt/infogather/embedding.py

%post
    set -eu
    pip install --no-cache-dir -r /opt/infogather/requirements.txt

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1

%runscript
    cd "$PWD"
    exec python /opt/infogather/embedding.py "$@"
