Bootstrap: docker
From: python:3.12-slim

%files
    requirements.txt /opt/infogather/requirements.txt
    base.py /opt/infogather/base.py

%post
    set -eu
    apt-get update
    apt-get install -y --no-install-recommends ca-certificates curl
    rm -rf /var/lib/apt/lists/*
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    uv pip install --system --no-cache -r /opt/infogather/requirements.txt

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export PATH="/root/.local/bin:$PATH"

%runscript
    cd "$PWD"
    exec python /opt/infogather/base.py "$@"
